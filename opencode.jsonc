{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "websearch": "allow",
    "webfetch": "allow",
    "question": "deny", // questions take over the UI in opencode
    "bash": {
      "*": "ask",

      "basename *": "allow",
      "cat *": "allow",
      "comm *": "allow",
      "cut *": "allow",
      "df *": "allow",
      "dirname *": "allow",
      "du *": "allow",
      "echo *": "allow",
      "file *": "allow",
      "git blame *": "allow",
      "git describe *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git merge-base *": "allow",
      "git rev-parse *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "kubectl get *": "allow",
      "kubectl logs *": "allow",
      "ls *": "allow",
      "otool *": "allow",
      "pwd": "allow",
      "readlink *": "allow",
      "realpath *": "allow",
      "rg *": "allow",
      "sort *": "allow",
      "stat *": "allow",
      "strings *": "allow",
      "tail *": "allow",
      "tree *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      "which *": "allow",

      "jq *": "ask", // shell()
      "tar *": "ask", // --to-command or --use-compress-program

      "awk *": "deny", // system()
      "find *": "deny" // -exec
    }
  },
  "default_agent": "plan",
  "agent": {
    // "plan": { "model": "openai/gpt-5.4" }, "build": { "model": "openai/gpt-5.4-mini" }
    "plan": { "model": "openai/gpt-5.3-codex" }, "build": { "model": "openai/gpt-5.4-mini" }
    // "plan": { "model": "opencode-go/glm-5.1" }, "build": { "model": "opencode-go/minimax-m2.7" }
    // "plan": { "model": "opencode-go/glm-5.1" }, "build": { "model": "opencode-go/qwen3.5-plus" }
  },
  "provider": {
    "lm-studio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "qwen3.5-4b-mlx": {
          "name": "qwen3.5-4b-mlx (local)",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "plugin": [
    // gitignore opencode-notifier-state.json
    "@mohak34/opencode-notifier@latest"
  ]
}
