{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "websearch": "ask",
    "webfetch": "ask",
    "bash": {
      "*": "ask",

      "basename *": "allow",
      "cat *": "allow",
      "comm *": "allow",
      "cut *": "allow",
      "df *": "allow",
      "dirname *": "allow",
      "du *": "allow",
      "echo *": "allow",
      "file *": "allow",
      "git blame *": "allow",
      "git describe *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git merge-base *": "allow",
      "git rev-parse *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "kubectl get *": "allow",
      "kubectl logs *": "allow",
      "ls *": "allow",
      "otool *": "allow",
      "pwd": "allow",
      "readlink *": "allow",
      "realpath *": "allow",
      "rg *": "allow",
      "sort *": "allow",
      "stat *": "allow",
      "strings *": "allow",
      "tail *": "allow",
      "tree *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      "which *": "allow",

      "jq *": "ask", // shell()
      "tar *": "ask", // --to-command or --use-compress-program

      "find *": "deny" // -exec (and can be done other ways)
    }
  },
  "model": "ollama/glm-5.1:cloud",
  "default_agent": "plan",
  "enabled_providers": [
    "ollama",
    "lm-studio",
    "openai",
    "opencode-go"
  ],
  "provider": {
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
